<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="<%= post.excerpt %>" />
  <meta name="keywords" content="<%= post.tags?.join(', ') || '' %>" />
  <meta property="og:title" content="<%= post.title %>" />
  <meta property="og:description" content="<%= post.excerpt %>" />
  <% if (post.featured_image) { %>
    <meta property="og:image" content="<%= post.featured_image %>" />
  <% } %>
  <title><%= post.title %> — BurnLink Blog</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #0a0a0a; color: #fff; line-height: 1.6; overflow-x: hidden;
    }
    .container { max-width: 900px; margin: 0 auto; padding: 0 2rem; }

    /* ── Header ── */
    header {
      padding: 1.75rem 0; border-bottom: 1px solid #1e1e1e;
      position: sticky; top: 0; background: #0a0a0a; z-index: 100;
    }
    .header-content { display: flex; justify-content: space-between; align-items: center; }
    .logo { text-decoration: none; display: flex; align-items: center; }
    .logo img { height: 45px; width: auto; display: block; }
    nav { display: flex; gap: 2.5rem; }
    nav a { text-decoration: none; color: #666; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; transition: color 0.2s; }
    nav a:hover, nav a.active { color: #fff; }

    /* ── Main ── */
    main { padding: 4rem 0 6rem; min-height: calc(100vh - 140px); }

    /* ── Breadcrumb ── */
    .breadcrumb {
      display: flex; gap: 0.75rem; align-items: center; font-size: 0.8rem;
      color: #666; margin-bottom: 2rem;
    }
    .breadcrumb a { color: #666; text-decoration: none; transition: color 0.2s; }
    .breadcrumb a:hover { color: #eb583d; }
    .breadcrumb-sep { color: #444; }

    /* ── Article Header ── */
    .article-header {
      margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid #1e1e1e;
    }
    .article-meta {
      display: flex; flex-wrap: wrap; gap: 1.5rem; font-size: 0.85rem;
      color: #666; margin-bottom: 1.5rem;
    }
    .article-category {
      display: inline-block; padding: 0.3rem 0.8rem;
      background: rgba(235, 88, 61, 0.1); color: #eb583d; font-weight: 600;
      text-transform: capitalize;
    }
    .article-author { display: flex; align-items: center; gap: 0.5rem; }
    .article-author-avatar {
      width: 28px; height: 28px; border-radius: 50%;
      background: linear-gradient(135deg, #eb583d, #ff7a5c);
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-weight: 700; font-size: 0.75rem;
    }

    h1 {
      font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; line-height: 1.15;
      letter-spacing: -0.02em; margin-bottom: 1rem; color: #fff;
    }
    .article-excerpt {
      font-size: 1.1rem; color: #aaa; line-height: 1.6; font-style: italic;
    }

    .article-featured-image {
      width: 100%; max-height: 400px; object-fit: cover;
      border: 1px solid #1e1e1e; margin: 3rem 0; border-radius: 4px;
    }

    /* ── Article Content ── */
    .article-content {
      font-size: 1rem; line-height: 1.75; color: #ddd;
    }
    .article-content h2 {
      font-size: 1.5rem; font-weight: 700; margin: 2rem 0 1rem;
      padding-top: 1rem; border-top: 1px solid #1a1a1a;
    }
    .article-content h3 {
      font-size: 1.2rem; font-weight: 600; margin: 1.5rem 0 0.75rem;
      color: #fff;
    }
    .article-content p {
      margin-bottom: 1.5rem;
    }
    .article-content strong { color: #eb583d; font-weight: 700; }
    .article-content em { font-style: italic; color: #bbb; }
    .article-content a {
      color: #eb583d; text-decoration: none; border-bottom: 1px solid #eb583d;
      transition: all 0.2s;
    }
    .article-content a:hover { color: #ff7a5c; border-bottom-color: #ff7a5c; }

    .article-content ul, .article-content ol {
      margin-left: 1.5rem; margin-bottom: 1.5rem;
    }
    .article-content li {
      margin-bottom: 0.5rem;
    }
    .article-content blockquote {
      border-left: 3px solid #eb583d; padding-left: 1.5rem;
      margin: 2rem 0; color: #999; font-style: italic;
    }
    .article-content code {
      background: #111; padding: 0.2rem 0.4rem; border-radius: 2px;
      color: #ffa366; font-family: "Monaco", "Menlo", monospace; font-size: 0.9rem;
    }
    .article-content pre {
      background: #111; border: 1px solid #222; padding: 1.5rem;
      border-radius: 4px; overflow-x: auto; margin: 1.5rem 0;
    }
    .article-content pre code {
      background: none; padding: 0; color: #ffa366;
    }

    /* ── Article Tags ── */
    .article-tags {
      display: flex; flex-wrap: wrap; gap: 0.75rem; margin: 2rem 0;
      padding: 2rem 0; border-top: 1px solid #1a1a1a; border-bottom: 1px solid #1a1a1a;
    }
    .tag {
      padding: 0.4rem 0.9rem; border: 1px solid #222; color: #666;
      text-decoration: none; font-size: 0.8rem; transition: all 0.2s;
      background: transparent;
    }
    .tag:hover { border-color: #eb583d; color: #eb583d; }

    /* ── Article Footer ── */
    .article-footer {
      display: flex; justify-content: space-between; align-items: center;
      padding: 2rem 0; border-bottom: 1px solid #1a1a1a; margin-bottom: 3rem;
    }
    .article-stats {
      display: flex; gap: 1.5rem; font-size: 0.8rem; color: #666;
    }
    .share-buttons {
      display: flex; gap: 1rem;
    }
    .share-btn {
      padding: 0.6rem 1rem; border: 1px solid #222; background: transparent;
      color: #666; text-decoration: none; cursor: pointer; font-size: 0.8rem;
      transition: all 0.2s; text-transform: uppercase; font-weight: 600;
      letter-spacing: 0.05em;
    }
    .share-btn:hover {
      border-color: #eb583d; color: #eb583d;
    }

    /* ── Related Posts ── */
    .related-posts {
      margin-top: 4rem; padding-top: 3rem; border-top: 1px solid #1e1e1e;
    }
    .related-posts h2 {
      font-size: 1.5rem; font-weight: 700; margin-bottom: 2rem;
    }
    .related-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }
    .related-card {
      border: 1px solid #1e1e1e; padding: 1.5rem;
      transition: all 0.3s; cursor: pointer;
      display: block;
      color: #fff;
      text-decoration: none;
    }
    .related-card::before {
      content: ""; position: absolute; top: 0; left: 0; width: 100%;
      height: 2px; background: #eb583d; transform: scaleX(0);
      transform-origin: left; transition: transform 0.3s;
    }
    .related-card:hover::before { transform: scaleX(1); }
    .related-card:hover {
      border-color: #eb583d; transform: translateY(-2px);
      color: #fff;
    }
    .related-card-title {
      font-weight: 700; font-size: 0.95rem; margin-bottom: 0.75rem;
      line-height: 1.4;
      color: #fff;
    }
    .related-card-excerpt {
      color: #888; font-size: 0.85rem; line-height: 1.5;
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
      overflow: hidden; margin-bottom: 1rem;
    }
    .related-card-date {
      font-size: 0.75rem; color: #666;
    }
    .related-card a {
      text-decoration: none; color: #fff;
    }

    /* ── Comment Section ── */
    .comments-section {
      margin-top: 4rem; padding-top: 2rem;
    }
    .comments-section h2 {
      font-size: 1.3rem; font-weight: 700; margin-bottom: 2rem;
    }

    /* ── Footer ── */
    footer { border-top: 1px solid #1e1e1e; padding: 3rem 0; }
    .footer-content { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 2rem; margin-bottom: 2rem; }
    .footer-section h3 { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.12em; font-weight: 600; margin-bottom: 1rem; color: #555; }
    .footer-section a { display: block; color: #777; text-decoration: none; font-size: 0.85rem; margin-bottom: 0.5rem; transition: color 0.2s; }
    .footer-section a:hover { color: #fff; }
    .footer-bottom { border-top: 1px solid #1e1e1e; padding-top: 1.5rem; color: #444; font-size: 0.78rem; }

    /* ── Table of Contents ── */
    .toc {
      background: #0f0f0f; border: 1px solid #1e1e1e; padding: 1.5rem;
      margin: 2rem 0; border-radius: 4px;
    }
    .toc h3 {
      font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.1em;
      color: #666; margin-bottom: 1rem;
    }
    .toc ul { list-style: none; margin-left: 0; }
    .toc li { margin-bottom: 0.5rem; }
    .toc a {
      color: #888; text-decoration: none; font-size: 0.9rem;
      border-bottom: none; transition: color 0.2s;
    }
    .toc a:hover { color: #eb583d; }

    @media (max-width: 768px) {
      nav { gap: 1rem; }
      h1 { font-size: 1.75rem; }
      .article-footer { flex-direction: column; gap: 1rem; align-items: flex-start; }
      .article-content { font-size: 0.95rem; }
      .related-grid { grid-template-columns: 1fr; }
      main { padding: 2rem 0; }
    }
  </style>
</head>
<body>
  <header>
    <div class="container">
      <div class="header-content">
        <a href="/" class="logo"><img src="/logo1.png" alt="BurnLink" /></a>
        <nav>
          <a href="/">Home</a>
          <a href="/blog" class="active">Blog</a>
          <a href="/about">About</a>
          <a href="/changelog">Changelog</a>
          <a href="/roadmap">Roadmap</a>
        </nav>
      </div>
    </div>
  </header>

  <main>
    <div class="container">
      <div class="breadcrumb">
        <a href="/blog">Blog</a>
        <span class="breadcrumb-sep">/</span>
        <a href="/blog?category=<%= post.category %>"><%= post.category %></a>
        <span class="breadcrumb-sep">/</span>
        <span><%= post.title %></span>
      </div>

      <article>
        <header class="article-header">
          <div class="article-meta">
            <span class="article-category"><%= post.category %></span>
            <img src="/logo1.png" alt="BurnLink" style="width: 24px; height: 24px; object-fit: contain;" />
            <div class="article-author">
              <span><%= post.author %></span>
            </div>
            <span><%= new Date(post.published_at).toLocaleDateString('en-US', { 
              year: 'numeric', month: 'long', day: 'numeric' 
            }) %></span>
            <% if (post.reading_time) { %>
              <span><%= post.reading_time %> min read</span>
            <% } %>
            <% if (post.views_count) { %>
              <span><%= post.views_count.toLocaleString() %> views</span>
            <% } %>
          </div>

          <h1><%= post.title %></h1>
          <% if (post.excerpt) { %>
            <p class="article-excerpt"><%= post.excerpt %></p>
          <% } %>
        </header>

        <div style="margin: 2rem 0;">
          <% if (post.featured_image) { %>
            <img src="<%= post.featured_image %>" alt="<%= post.title %>" class="article-featured-image" />
          <% } %>
        </div>

        <div class="article-content">
          <%- post.content %>
        </div>

        <% if (post.tags && post.tags.length > 0) { %>
          <div class="article-tags">
            <% post.tags.forEach(tag => { %>
              <a href="/blog?tag=<%= tag %>" class="tag">#<%= tag %></a>
            <% }); %>
          </div>
        <% } %>

        <div class="article-footer">
          <div class="article-stats">
            <span>Published <%= new Date(post.published_at).toLocaleDateString() %></span>
            <span>Last updated <%= new Date(post.updated_at).toLocaleDateString() %></span>
          </div>
          <div class="share-buttons">
            <a href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent('https://burnlink.page/blog/' + post.slug) %>&text=<%= encodeURIComponent(post.title) %>"
               class="share-btn" target="_blank">
              Share on Twitter
            </a>
            <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= encodeURIComponent('https://burnlink.page/blog/' + post.slug) %>"
               class="share-btn" target="_blank">
              Share on LinkedIn
            </a>
          </div>
        </div>
      </article>

      <% if (relatedPosts && relatedPosts.length > 0) { %>
        <section class="related-posts">
          <h2>Related Posts</h2>
          <div class="related-grid">
            <% relatedPosts.forEach(relatedPost => { %>
              <a href="/blog/<%= relatedPost.slug %>" class="related-card">
                <div class="related-card-title"><%= relatedPost.title %></div>
                <div class="related-card-excerpt"><%= relatedPost.excerpt %></div>
                <div class="related-card-date">
                  <%= new Date(relatedPost.published_at).toLocaleDateString() %>
                </div>
              </a>
            <% }); %>
          </div>
        </section>
      <% } %>

      <section class="comments-section">
        <h2>Discussion</h2>
        
        <!-- Comment Form -->
        <div style="background: #0f0f0f; border: 1px solid #1e1e1e; padding: 2rem; margin-bottom: 3rem; border-radius: 4px;">
          <h3 style="font-size: 1.1rem; margin-bottom: 1.5rem; color: #fff;">Add Your Comment</h3>
          <form id="commentForm" style="display: flex; flex-direction: column; gap: 1rem;">
            <input 
              type="text" 
              placeholder="Your name" 
              id="authorName"
              required
              style="padding: 0.75rem; background: #111; border: 1px solid #222; color: #fff; border-radius: 2px; font-family: inherit;"
            />
            <input 
              type="email" 
              placeholder="Your email (will not be displayed)" 
              id="authorEmail"
              required
              style="padding: 0.75rem; background: #111; border: 1px solid #222; color: #fff; border-radius: 2px; font-family: inherit;"
            />
            <textarea 
              placeholder="Share your thoughts..." 
              id="commentContent"
              rows="4"
              required
              style="padding: 0.75rem; background: #111; border: 1px solid #222; color: #fff; border-radius: 2px; font-family: inherit; resize: vertical;"
            ></textarea>
            <button 
              type="submit"
              style="padding: 0.8rem 1.5rem; background: #eb583d; color: #fff; border: none; border-radius: 2px; cursor: pointer; font-weight: 600; transition: background 0.2s;"
            >
              Post Comment
            </button>
          </form>
          <div id="commentStatus" style="margin-top: 1rem; display: none; padding: 0.75rem; border-radius: 2px;"></div>
        </div>

        <!-- Comments List -->
        <div id="commentsList" style="max-width: 100%;">
          <div style="text-align: center; color: #666; padding: 2rem;">Loading comments...</div>
        </div>
      </section>
    </div>
  </main>

  <script nonce="<%= cspNonce %>">
    document.addEventListener("DOMContentLoaded", async () => {
      const postSlug = window.location.pathname.split("/").pop();
      
      // Load comments
      async function loadComments() {
        try {
          const response = await fetch(`/api/blog/${postSlug}/comments`);
          const comments = await response.json();
          
          const commentsList = document.getElementById("commentsList");
          
          if (!Array.isArray(comments) || comments.length === 0) {
            commentsList.innerHTML = '<div style="text-align: center; color: #666; padding: 2rem;">No comments yet. Be the first to share your thoughts!</div>';
            return;
          }
          
          commentsList.innerHTML = comments.map(comment => `
            <div style="border: 1px solid #1e1e1e; padding: 1.5rem; margin-bottom: 1rem; border-radius: 4px;">
              <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 0.75rem;">
                <div>
                  <strong style="color: #fff;">${escapeHtml(comment.author_name)}</strong>
                  <div style="font-size: 0.75rem; color: #666;">
                    ${new Date(comment.created_at).toLocaleDateString('en-US', { 
                      year: 'numeric', month: 'long', day: 'numeric'
                    })}
                  </div>
                </div>
              </div>
              <p style="color: #ddd; line-height: 1.6;">${escapeHtml(comment.content)}</p>
            </div>
          `).join('');
        } catch (err) {
          console.error("Error loading comments:", err);
          document.getElementById("commentsList").innerHTML = '<div style="text-align: center; color: #666; padding: 2rem;">Failed to load comments</div>';
        }
      }

      // Handle form submission
      document.getElementById("commentForm").addEventListener("submit", async (e) => {
        e.preventDefault();
        
        const authorName = document.getElementById("authorName").value;
        const authorEmail = document.getElementById("authorEmail").value;
        const content = document.getElementById("commentContent").value;
        const statusDiv = document.getElementById("commentStatus");
        
        try {
          const response = await fetch(`/api/blog/${postSlug}/comments`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ authorName, authorEmail, content })
          });
          
          const result = await response.json();
          
          if (response.ok) {
            statusDiv.style.display = "block";
            statusDiv.style.background = "#1a3a1a";
            statusDiv.style.color = "#6b9c6b";
            statusDiv.innerHTML = "✓ Comment submitted! It will appear after moderation.";
            document.getElementById("commentForm").reset();
            setTimeout(() => {
              statusDiv.style.display = "none";
            }, 5000);
          } else {
            throw new Error(result.error);
          }
        } catch (err) {
          statusDiv.style.display = "block";
          statusDiv.style.background = "#3a1a1a";
          statusDiv.style.color = "#c76b6b";
          statusDiv.innerHTML = "Failed to post comment: " + err.message;
        }
      });

      // Load comments on page load
      loadComments();
    });

    function escapeHtml(text) {
      const map = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#039;"
      };
      return text.replace(/[&<>"']/g, m => map[m]);
    }
  </script>
  </main>

  <%- include("../partials/footer") %>

  <script>
    // Add copy to clipboard functionality for code blocks
    document.querySelectorAll(".article-content pre").forEach((block) => {
      const code = block.querySelector("code");
      const button = document.createElement("button");
      button.textContent = "Copy";
      button.style.cssText = `
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        padding: 0.4rem 0.8rem;
        background: #eb583d;
        color: #fff;
        border: none;
        cursor: pointer;
        font-size: 0.75rem;
        border-radius: 2px;
      `;

      button.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(code.textContent);
          button.textContent = "Copied!";
          setTimeout(() => (button.textContent = "Copy"), 2000);
        } catch (err) {
          console.error("Failed to copy:", err);
        }
      });

      block.style.position = "relative";
      block.appendChild(button);
    });

    // Smooth scroll to anchor links
    document.querySelectorAll('a[href^="#"]').forEach((link) => {
      link.addEventListener("click", function (e) {
        const target = document.querySelector(this.getAttribute("href"));
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: "smooth" });
        }
      });
    });
  </script>
</body>
</html>
